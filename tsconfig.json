{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "typeRoots": ["./.ts-toolchain/node_modules/@types"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "scripts/**/*.js",
    "test/**/*.ts"
  ]
}
